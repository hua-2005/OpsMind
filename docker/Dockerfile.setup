# OpsMind AnythingLLM 自动初始化容器
# 在 anythingllm 首次启动后自动创建 API Key，实现 docker compose up -d 一键部署
#
# 原理：直接写入 AnythingLLM 的 SQLite 数据库（/app/server/storage/anythingllm.db），
# 绕过浏览器手动创建 API Key 的步骤。
FROM alpine:3.20

RUN apk add --no-cache sqlite openssl

COPY scripts/init-api-key.sh /init-api-key.sh
RUN chmod +x /init-api-key.sh

ENTRYPOINT ["/init-api-key.sh"]
