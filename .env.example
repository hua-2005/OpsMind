# OpsMind v2 本地开发环境变量模板
#
# 复制此文件为 .env 并根据环境修改：
#   cp .env.example .env
#
# .env 文件已加入 .gitignore，不会被提交到版本库。
#
# ============================================================
# 快速开始:
#   1. cp .env.example .env
#   2. 设置 JWT_SECRET（必填）
#   3. 选择 LLM 提供商（见下方 LLM 配置区）
#   4. docker compose up -d --build
#   5. (可选) 下载模型: make model-download
#   6. (可选) docker compose --profile ai-local up -d llama-cpp
# ============================================================

# ===== PostgreSQL + pgvector =====
POSTGRES_PASSWORD=opsmind_dev

# ===== MinIO 对象存储 =====
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ===== OpsMind 后端 =====
# 生产部署必须修改为随机强密码（32 字符以上）
JWT_SECRET=change-me-to-a-random-string-32-chars

# ======================================================================
# LLM + Embedding 配置
# ======================================================================
# v2 直接调用 OpenAI-compatible API，LLM 和 Embedding 共用同一 Base URL。
# 支持 llama.cpp server、OpenAI、DeepSeek、Moonshot 等所有兼容服务。
# 根据需要选择下面一种方案，注释掉其余。

# ----- 方案 A：本地 llama.cpp（推荐，完全本地化）-----
# 需要下载 .gguf 模型文件到 ./models 目录。
# 启动命令: docker compose --profile ai-local up -d --build
LLM_BASE_URL=http://llama-cpp:8080/v1
LLM_API_KEY=
LLM_MODEL=qwen3-4b
LLM_MAX_TOKENS=8192
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSION=1024

# ----- 方案 B：OpenAI 官方 API（最简单，按量付费）-----
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-your-openai-api-key
# LLM_MODEL=gpt-4o-mini
# LLM_MAX_TOKENS=16384
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536

# ----- 方案 C：DeepSeek =----
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_API_KEY=sk-your-deepseek-api-key
# LLM_MODEL=deepseek-chat
# LLM_MAX_TOKENS=16384
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536

# ----- 方案 D：其他 OpenAI 兼容服务 =----
# LLM_BASE_URL=https://your-service/v1
# LLM_API_KEY=your-api-key
# LLM_MODEL=your-model
# LLM_MAX_TOKENS=8192
# EMBEDDING_MODEL=your-embedding-model
# EMBEDDING_DIMENSION=1024

# ===== RAG 参数 =====
AI_CONFIDENCE_THRESHOLD=0.6
AI_DEFAULT_TOP_K=5

# ===== llama.cpp 模型目录（仅方案 A 需要）=====
LLAMA_MODELS_DIR=./models
