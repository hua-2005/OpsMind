# OpsMind 本地开发环境变量模板
#
# 复制此文件为 .env 并根据环境修改：
#   cp .env.example .env
#
# .env 文件已加入 .gitignore，不会被提交到版本库。
#
# ============================================================
# 快速开始:
#   1. cp .env.example .env
#   2. 设置 OPSMIND_JWT_SECRET（必填）
#   3. docker compose up -d --build
#   4. (可选) 下载模型: make model-download
#   5. (可选) 配置 AnythingLLM API Key
# ============================================================

# ===== PostgreSQL =====
POSTGRES_PASSWORD=opsmind_dev

# ===== MinIO 对象存储 =====
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ===== OpsMind 后端 =====
# 生产部署必须修改为随机强密码（32 字符以上）
OPSMIND_JWT_SECRET=change-me-to-a-random-string-32-chars

# ===== AnythingLLM 内部组件 =====
# AnythingLLM 地址（Docker 内部使用服务名 anythingllm）
ANYTHINGLLM_BASE_URL=http://anythingllm:3001/api
# ⚠️ 部署后必须通过管理页面创建 API Key 并填入此处：
#    1. 取消 docker-compose.yml 中 anythingllm ports 注释
#    2. docker compose up -d anythingllm
#    3. 浏览器访问 http://localhost:3001 完成初始化
#    4. Settings → API Keys → 创建 Key → 填入下方
ANYTHINGLLM_API_KEY=replace-after-create-api-key
# 以下三项随机生成即可（20-32 字符）
ANYTHINGLLM_JWT_SECRET=replace-with-random-string-20-plus
ANYTHINGLLM_SIG_KEY=replace-with-random-string-32-plus
ANYTHINGLLM_SIG_SALT=replace-with-random-string-32-plus

# ===== vLLM / 模型推理 =====
# 使用前需要先下载模型文件到 ./models/ 目录：
#   make model-download
#   或手动: modelscope download --model Qwen/Qwen2.5-7B-Instruct --local_dir ./models/qwen2.5-7b-instruct
# 启动含 vLLM 的完整环境：
#   docker compose --profile ai-local up -d --build
VLLM_BASE_URL=http://vllm:8000/v1
VLLM_MODEL=qwen2.5-7b-instruct
VLLM_TOKEN_LIMIT=8192
VLLM_API_KEY=dummy-key

# ===== Embedding 服务 =====
# BGE-M3 模型同样需要下载：
#   modelscope download --model BAAI/bge-m3 --local_dir ./models/bge-m3
EMBEDDING_BASE_URL=http://vllm:8000/v1
EMBEDDING_MODEL=bge-m3
EMBEDDING_MAX_CHUNK_LENGTH=8192
EMBEDDING_API_KEY=dummy-key
